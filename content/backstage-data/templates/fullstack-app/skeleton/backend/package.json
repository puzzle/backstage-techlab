{
  "name": "${{ values.name }}-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "test": "jest"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.0",
    {% if values.database == 'postgresql' %}
    "pg": "^8.11.0"
    {% elif values.database == 'mysql' %}
    "mysql2": "^3.6.0"
    {% elif values.database == 'mongodb' %}
    "mongodb": "^6.3.0"
    {% endif %}
    {% if values.includeAuth %}
    ,"jsonwebtoken": "^9.0.2",
    "bcrypt": "^5.1.1"
    {% endif %}
  },
  "devDependencies": {
    "nodemon": "^3.0.0",
    "jest": "^29.7.0"
  }
}
